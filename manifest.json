{
  "manifest_version": 3,
  "name": "Claude Web Chat Folders",
  "version": "0.2.0",
  "description": "Folder organization for claude.ai chats. Local storage only, no API access, no telemetry.",
  "key": "",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["https://claude.ai/*"],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Claude Chat Folders"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/content.js"],
      "css": ["src/content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/content/main.js",
        "src/content/folder-strip.js",
        "src/content/folder-panel.js",
        "src/content/drag-handlers.js",
        "src/content/settings-overlay.js",
        "src/lib/storage.js",
        "src/lib/selectors.js",
        "src/lib/themes.js"
      ],
      "matches": ["https://claude.ai/*"]
    }
  ]
}
